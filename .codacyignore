# Exclude build artifacts, dependencies, docs, and editor files from Codacy analysis

# This prevents linters from scanning generated files like Next.js build output and node_modules

# Next.js build output

/.next/
frontend/.next/

# Node modules / vendor

/node_modules/
frontend/node_modules/

# Docs, markdown and repo metadata

/docs/
/*.md
.github/

# Misc

.DS_Store
coverage/
dist/
build/
