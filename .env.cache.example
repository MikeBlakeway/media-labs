# Model Cache Management Configuration

# =============================================================================
# Cache Management Settings
# =============================================================================

# Volume usage thresholds (percentage)
CACHE_HIGH_WATER_MARK=90          # Trigger automatic eviction at 90% usage
CACHE_LOW_WATER_MARK=75           # Stop eviction when usage drops to 75%

# Model protection settings
CACHE_MIN_HEAT_SCORE=0.1          # Minimum heat score to keep model (0.0-2.0)
CACHE_PROTECTION_HOURS=24         # Hours to protect recently accessed models

# Cleanup scheduling (cron format)
CACHE_CLEANUP_SCHEDULE="0 2 * * *" # Daily cleanup at 2 AM UTC

# =============================================================================
# Advanced Cache Tuning (Optional)
# =============================================================================

# Heat score calculation weights (advanced users only)
# CACHE_ACCESS_WEIGHT=0.4         # Weight for access count factor
# CACHE_RECENCY_WEIGHT=0.3        # Weight for recency factor  
# CACHE_SIZE_PENALTY_WEIGHT=0.2   # Weight for size penalty factor
# CACHE_PIN_BONUS=0.5             # Bonus for pinned models
# CACHE_IN_USE_BONUS=1.0          # Bonus for models in use

# Eviction batch settings
# CACHE_MAX_EVICTION_BATCH=10     # Maximum models to evict in one operation
# CACHE_EVICTION_TIMEOUT=300      # Timeout for eviction operations (seconds)

# Analytics settings
# CACHE_ANALYTICS_RETENTION_DAYS=30   # Days to keep analytics data
# CACHE_METRICS_UPDATE_INTERVAL=300   # Seconds between metrics updates

# =============================================================================
# Integration Settings
# =============================================================================

# Volume worker integration (already configured in main .env)
# RUNPOD_VOLUME_WORKER_ENDPOINT_ID=your-endpoint-id
# RUNPOD_API_KEY=your-api-key
# USE_LOCAL_WORKER=false
# LOCAL_WORKER_URL=http://localhost:8000

# B2 cold storage integration (when implemented)
# B2_COLD_STORAGE_ENABLED=false
# B2_COLD_STORAGE_BUCKET=your-cold-storage-bucket
# B2_COLD_STORAGE_THRESHOLD_DAYS=30

# =============================================================================
# Monitoring and Alerting
# =============================================================================

# Webhook notifications (future feature)
# CACHE_WEBHOOK_URL=https://your-domain.com/webhooks/cache
# CACHE_WEBHOOK_EVENTS=high_usage,eviction_failed,no_evictable_models

# Metrics export (future feature)  
# CACHE_METRICS_ENDPOINT=https://your-monitoring.com/metrics
# CACHE_METRICS_API_KEY=your-metrics-api-key

# =============================================================================
# Development and Testing
# =============================================================================

# Enable debug logging
# DEBUG=cache:*

# Test mode settings
# CACHE_TEST_MODE=false           # Use mock data instead of real volume
# CACHE_DRY_RUN_DEFAULT=true     # Default evictions to dry-run mode
# CACHE_DISABLE_AUTO_EVICTION=false # Disable automatic eviction triggers

# =============================================================================
# Production Recommendations
# =============================================================================

# For production deployments, consider:
#
# 1. Database Integration:
#    - Replace in-memory storage with persistent database
#    - Use Redis for real-time cache state
#    - PostgreSQL for long-term analytics
#
# 2. Monitoring:
#    - Set up alerts for high volume usage
#    - Monitor eviction success rates
#    - Track cache efficiency metrics
#
# 3. Backup Strategy:
#    - Regular volume snapshots before major cleanups
#    - Model metadata backup to external storage
#    - Disaster recovery procedures
#
# 4. Performance Tuning:
#    - Adjust heat score weights based on usage patterns
#    - Fine-tune protection windows for your workload
#    - Monitor and optimize eviction batch sizes
#
# 5. Security:
#    - Restrict admin cache dashboard access
#    - Audit log for manual evictions
#    - Rate limiting for cache API endpoints