# Root environment placeholders
# For local development the API has its own .env.example at apps/api/.env.example

# Production / CI (example placeholder for Postgres)
# DATABASE_URL=postgresql://username:password@host:5432/media_labs?schema=public

# Cloud Mode Configuration
# VIDEO_RUN_MODE can be: local_fake, cloud
VIDEO_RUN_MODE=local_fake

# RunPod Configuration (required when VIDEO_RUN_MODE=cloud)
# RUNPOD_API_KEY=your-runpod-api-key
# RUNPOD_ENDPOINT_ID=your-runpod-endpoint-id
# RUNPOD_REGION=your-runpod-region

# Public URL Configuration
# PUBLIC_BASE_URL=https://your-domain.com

# Callback Security
# CALLBACK_SECRET=your-callback-hmac-secret

# B2 Storage Configuration (required when VIDEO_RUN_MODE=cloud)
# B2_ENDPOINT=your-b2-endpoint
# B2_REGION=your-b2-region
# B2_BUCKET=your-b2-bucket-name
# B2_ACCESS_KEY_ID=your-b2-access-key-id
# B2_SECRET_ACCESS_KEY=your-b2-secret-access-key