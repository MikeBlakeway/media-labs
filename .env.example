# Local development worker (set USE_LOCAL_WORKER=true to enable)
USE_LOCAL_WORKER=false
LOCAL_WORKER_URL=http://localhost:8000

# Runpod
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
RUNPOD_VOLUME_WORKER_ENDPOINT_ID=

# Runpod Network Volume (S3-compatible storage)
RUNPOD_VOLUME_ID=
RUNPOD_S3_ENDPOINT=
RUNPOD_S3_REGION=
RUNPOD_S3_ACCESS_KEY_ID=
RUNPOD_S3_SECRET_ACCESS_KEY=

# Backblaze B2 (S3-compatible outputs)
BUCKET_NAME=
BUCKET_ENDPOINT_URL=
BUCKET_REGION=
BUCKET_ACCESS_KEY_ID=
BUCKET_SECRET_ACCESS_KEY=

# ComfyUI models config
RUNPOD_MODELS_PREFIX=models
RUNPOD_MODEL_DIR_UNET=diffusion_models      # UNETLoader → models/diffusion_models/
RUNPOD_MODEL_DIR_CLIP=text_encoders         # CLIPLoader → models/text_encoders/
RUNPOD_MODEL_DIR_CLIP_VISION=clip_vision    # CLIPVisionLoader → models/clip_vision/
RUNPOD_MODEL_DIR_VAE=vae                    # VAELoader → models/vae/
RUNPOD_MODEL_DIR_LORA=loras                 # LoraLoader → models/loras/
RUNPOD_MODEL_DIR_CHECKPOINTS=checkpoints    # CheckpointLoader → models/checkpoints/

# Github
GITHUB_TOKEN=