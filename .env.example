# Runpod – job submission
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# Local development worker (set USE_LOCAL_WORKER=true to enable)
USE_LOCAL_WORKER=true
LOCAL_WORKER_URL=http://localhost:8000

# Runpod Network Volume (S3-compatible)
RUNPOD_S3_ENDPOINT=
RUNPOD_S3_REGION=
RUNPOD_VOLUME_ID=
RUNPOD_S3_ACCESS_KEY_ID=
RUNPOD_S3_SECRET_ACCESS_KEY=

# prefix under the bucket
RUNPOD_MODELS_PREFIX=models

# subfolder names for each model "type"
RUNPOD_MODEL_DIR_UNET=unet
RUNPOD_MODEL_DIR_CLIP=clip
RUNPOD_MODEL_DIR_CLIP_VISION=clip_vision
RUNPOD_MODEL_DIR_VAE=vae
RUNPOD_MODEL_DIR_LORA=loras
RUNPOD_MODEL_DIR_CHECKPOINTS=checkpoints

# Volume worker configuration
RUNPOD_VOLUME_WORKER_ENDPOINT_ID=your-endpoint-id
RUNPOD_API_KEY=your-api-key

# Backblaze B2 (S3-compatible outputs)
B2_S3_ENDPOINT=
B2_S3_REGION=
B2_S3_BUCKET=
B2_S3_ACCESS_KEY_ID=
B2_S3_SECRET_ACCESS_KEY=