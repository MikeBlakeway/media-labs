{
  "name": "media-labs-api",
  "version": "1.0.0",
  "description": "API for the Media Labs image-to-video web application",
  "main": "src/index.ts",
  "scripts": {
    "dev": "ts-node-dev src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write '**/*.{ts,json,md}'",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "prisma:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force && prisma db seed"
  },
  "dependencies": {
    "express": "^4.18.2",
    "@prisma/client": "^6.14.0"
  },
  "devDependencies": {
    "prisma": "^6.14.0",
    "typescript": "^5",
    "@types/express": "^4.17.13",
    "@types/node": "^20",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "eslint": "^9",
    "prettier": "^2.8.8"
  },
  "keywords": [
    "media",
    "labs",
    "api",
    "image-to-video"
  ],
  "author": "Your Name",
  "license": "MIT"
}
