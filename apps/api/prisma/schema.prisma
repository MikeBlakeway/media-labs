generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}
model Job {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  status        JobStatus @default(QUEUED)
  lane          JobLane  @default(VIDEO)
  params        Json
  inputs        Json?    // Array of input file descriptors
  sampleRate    Int?     // For audio jobs - sample rate (default 44100)
  channels      Int?     // For audio jobs - number of channels
  processing    Json?    // Processing configuration (mode, presets, etc.)
  metadata      Json?    // Additional metadata
  podId         String?
  progressPct   Int?
  outputKey     String?
  outputUrl     String?
  resultPaths   Json?    // Array of result file paths/URLs
  failureReason String?
  retries       Int      @default(0)
  attempts      Int      @default(0)
}

enum JobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELED
}

enum JobLane {
  VIDEO
  AUDIO
}