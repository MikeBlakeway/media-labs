  },
  "dependencies": {
    "@prisma/client": "^6.14.0"
  },
  "devDependencies": {
    "prisma": "^6.14.0",
    "typescript": "^5",
    "prettier": "^2.8.8",
    "ts-node": "^10.9.1",
    "@types/node": "^20",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "eslint": "8.57.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
