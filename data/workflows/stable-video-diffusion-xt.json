{
  "slug": "stable-video-diffusion-xt",
  "name": "Image to Video (SVD-XT 1.1)",
  "outputType": "video",
  "workflow": {
    "1": {
      "class_type": "LoadImage",
      "inputs": {
        "image": "input_image.png"
      },
      "_meta": {
        "title": "Load Input Image"
      }
    },
    "2": {
      "class_type": "StableVideoDiffusion_Sampler",
      "inputs": {
        "width": 1024,
        "height": 576,
        "video_frames": 25,
        "motion_bucket_id": 127,
        "fps": 6,
        "augmentation_level": 0.0,
        "seed": 42,
        "steps": 20,
        "cfg": 2.5,
        "sampler_name": "euler",
        "scheduler": "karras",
        "denoise": 1.0,
        "model": ["3", 0],
        "positive": ["4", 0],
        "negative": ["5", 0],
        "latent_image": ["6", 0],
        "image": ["1", 0]
      },
      "_meta": {
        "title": "SVD Sampler"
      }
    },
    "3": {
      "class_type": "CheckpointLoaderSimple",
      "inputs": {
        "ckpt_name": "svd_xt_1_1.safetensors"
      },
      "_meta": {
        "title": "Load SVD Model"
      }
    },
    "4": {
      "class_type": "SVD_img2vid_Conditioning",
      "inputs": {
        "width": 1024,
        "height": 576,
        "video_frames": 25,
        "motion_bucket_id": 127,
        "fps": 6,
        "augmentation_level": 0.0,
        "clip_vision": ["7", 0],
        "init_image": ["1", 0],
        "vae": ["3", 2]
      },
      "_meta": {
        "title": "SVD Conditioning"
      }
    },
    "5": {
      "class_type": "SVD_img2vid_Conditioning",
      "inputs": {
        "width": 1024,
        "height": 576,
        "video_frames": 25,
        "motion_bucket_id": 127,
        "fps": 6,
        "augmentation_level": 0.0,
        "clip_vision": ["7", 0],
        "init_image": ["1", 0],
        "vae": ["3", 2]
      },
      "_meta": {
        "title": "SVD Negative Conditioning"
      }
    },
    "6": {
      "class_type": "EmptySD3LatentImage",
      "inputs": {
        "width": 1024,
        "height": 576,
        "batch_size": 25
      },
      "_meta": {
        "title": "Empty Latent Video"
      }
    },
    "7": {
      "class_type": "CLIPVisionLoader",
      "inputs": {
        "clip_name": "CLIP-ViT-H-14.safetensors"
      },
      "_meta": {
        "title": "Load CLIP Vision"
      }
    },
    "8": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": ["2", 0],
        "vae": ["3", 2]
      },
      "_meta": {
        "title": "VAE Decode"
      }
    },
    "9": {
      "class_type": "CreateVideo",
      "inputs": {
        "fps": 6,
        "images": ["8", 0]
      },
      "_meta": {
        "title": "Create Video"
      }
    },
    "10": {
      "class_type": "SaveVideo",
      "inputs": {
        "filename_prefix": "i2v/MediaLabs",
        "format": "mp4",
        "codec": "h264",
        "video": ["9", 0]
      },
      "_meta": {
        "title": "Save Video"
      }
    }
  },
