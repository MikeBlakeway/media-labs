{
  "slug": "video-effects",
  "name": "Video Effects & Transformation (V2V)",
  "workflow": {
    "1": {
      "class_type": "LoadVideo",
      "inputs": {
        "video": "input_video.mp4"
      },
      "_meta": {
        "title": "Load Input Video"
      }
    },
    "2": {
      "class_type": "CheckpointLoaderSimple",
      "inputs": {
        "ckpt_name": "sd_xl_base_1.0.safetensors"
      },
      "_meta": {
        "title": "Load Base Model"
      }
    },
    "3": {
      "class_type": "LoraLoader",
      "inputs": {
        "model": ["2", 0],
        "clip": ["2", 1],
        "lora_name": "temporal_effects_lora.safetensors",
        "strength_model": 0.8,
        "strength_clip": 1.0
      },
      "_meta": {
        "title": "Load Effects LoRA"
      }
    },
    "4": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "cinematic effects, dramatic lighting, color grading, film look, atmospheric",
        "clip": ["3", 1]
      },
      "_meta": {
        "title": "Effects Prompt"
      }
    },
    "5": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "flat lighting, washed out colors, amateur look, overprocessed",
        "clip": ["3", 1]
      },
      "_meta": {
        "title": "Negative Prompt"
      }
    },
    "6": {
      "class_type": "VideoFrameExtractor",
      "inputs": {
        "video": ["1", 0],
        "frame_rate": 24,
        "max_frames": 360
      },
      "_meta": {
        "title": "Extract Video Frames"
      }
    },
    "7": {
      "class_type": "ColorCorrection",
      "inputs": {
        "images": ["6", 0],
        "brightness": 1.1,
        "contrast": 1.2,
        "saturation": 1.15,
        "gamma": 1.0
      },
      "_meta": {
        "title": "Color Correction"
      }
    },
    "8": {
      "class_type": "TemporalStabilizer",
      "inputs": {
        "images": ["7", 0],
        "strength": 0.7,
        "window_size": 5
      },
      "_meta": {
        "title": "Temporal Stabilization"
      }
    },
    "9": {
      "class_type": "VAEEncode",
      "inputs": {
        "pixels": ["8", 0],
        "vae": ["2", 2]
      },
      "_meta": {
        "title": "Encode Enhanced Frames"
      }
    },
    "10": {
      "class_type": "KSampler",
      "inputs": {
        "seed": 24680,
        "steps": 20,
        "cfg": 6.5,
        "sampler_name": "dpmpp_sde",
        "scheduler": "karras",
        "denoise": 0.35,
        "model": ["3", 0],
        "positive": ["4", 0],
        "negative": ["5", 0],
        "latent_image": ["9", 0]
      },
      "_meta": {
        "title": "Apply Cinematic Effects"
      }
    },
    "11": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": ["10", 0],
        "vae": ["2", 2]
      },
      "_meta": {
        "title": "Decode Processed Frames"
      }
    },
    "12": {
      "class_type": "FilmGrain",
      "inputs": {
        "images": ["11", 0],
        "strength": 0.15,
        "type": "35mm"
      },
      "_meta": {
        "title": "Add Film Grain"
      }
    },
    "13": {
      "class_type": "CreateVideo",
      "inputs": {
        "fps": 24,
        "images": ["12", 0]
      },
      "_meta": {
        "title": "Create Enhanced Video"
      }
    },
    "14": {
      "class_type": "SaveVideo",
      "inputs": {
        "filename_prefix": "video/effects_",
        "format": "mp4",
        "codec": "h264",
        "video": ["13", 0]
      },
      "_meta": {
        "title": "Save Enhanced Video"
      }
    }
  },
  "fields": [
