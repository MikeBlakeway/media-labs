      "inputKey": "fps"
    },
    {
      "id": "save_14_prefix",
      "label": "Filename Prefix",
      "type": "string",
      "required": false,
      "defaultValue": "video/interpolated_",
      "nodeId": "14",
      "inputKey": "filename_prefix"
    }
  ],
  "createdAt": 1757377320000
}
