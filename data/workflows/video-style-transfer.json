      "defaultValue": 15,
      "nodeId": "9",
      "inputKey": "steps"
    },
    {
      "id": "ks_9_cfg",
      "label": "CFG Scale",
      "type": "number",
      "required": true,
      "defaultValue": 7.0,
      "nodeId": "9",
