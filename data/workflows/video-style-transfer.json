    },
    {
      "id": "ks_9_denoise",
      "label": "Denoise Strength",
      "type": "number",
      "required": true,
      "defaultValue": 0.6,
      "nodeId": "9",
      "inputKey": "denoise"
    },
    {
      "id": "video_7_frame_rate",
      "label": "Processing Frame Rate",
      "type": "integer",
      "required": true,
      "defaultValue": 12,
      "nodeId": "7",
      "inputKey": "frame_rate"
    },
    {
      "id": "video_7_max_frames",
      "label": "Max Frames to Process",
      "type": "integer",
      "required": true,
      "defaultValue": 120,
      "nodeId": "7",
      "inputKey": "max_frames"
    },
    {
      "id": "create_11_fps",
      "label": "Output Video FPS",
      "type": "integer",
      "required": true,
      "defaultValue": 24,
      "nodeId": "11",
      "inputKey": "fps"
    },
    {
      "id": "save_12_prefix",
      "label": "Filename Prefix",
      "type": "string",
