      "defaultValue": 24,
      "nodeId": "7",
      "inputKey": "frame_rate"
    },
    {
      "id": "video_7_max_frames",
      "label": "Max Frames to Process",
      "type": "integer",
      "required": true,
      "defaultValue": 300,
      "nodeId": "7",
      "inputKey": "max_frames"
    },
    {
      "id": "create_13_fps",
      "label": "Output Video FPS",
      "type": "integer",
      "required": true,
      "defaultValue": 24,
      "nodeId": "13",
      "inputKey": "fps"
    },
    {
      "id": "save_14_prefix",
      "label": "Filename Prefix",
      "type": "string",
      "required": false,
      "defaultValue": "video/upscaled_",
      "nodeId": "14",
      "inputKey": "filename_prefix"
    }
  ],
  "createdAt": 1757377260000
}
