      "nodeId": "8",
      "inputKey": "model_name"
    },
    {
      "id": "vae_3_vae_name",
      "label": "VAE Model",
      "type": "string",
      "required": true,
      "defaultValue": "vae-ft-mse-840000-ema-pruned.safetensors",
      "nodeId": "3",
      "inputKey": "vae_name"
    },
    {
      "id": "ks_11_seed",
      "label": "Seed",
      "type": "integer",
      "required": false,
      "defaultValue": 12345,
      "nodeId": "11",
      "inputKey": "seed"
    },
    {
      "id": "ks_11_steps",
      "label": "Refinement Steps",
      "type": "integer",
      "required": true,
      "defaultValue": 8,
      "nodeId": "11",
      "inputKey": "steps"
    },
    {
      "id": "ks_11_cfg",
      "label": "CFG Scale",
      "type": "number",
      "required": true,
      "defaultValue": 2.0,
      "nodeId": "11",
      "inputKey": "cfg"
    },
    {
      "id": "ks_11_denoise",
      "label": "Refinement Strength",
      "type": "number",
      "required": true,
      "defaultValue": 0.3,
      "nodeId": "11",
      "inputKey": "denoise"
    },
    {
      "id": "video_7_frame_rate",
      "label": "Processing Frame Rate",
      "type": "integer",
