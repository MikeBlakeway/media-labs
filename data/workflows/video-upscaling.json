{
  "slug": "video-upscaling",
  "name": "Video Upscaling (V2V)",
  "workflow": {
    "1": {
      "class_type": "LoadVideo",
      "inputs": {
        "video": "input_video.mp4"
      },
      "_meta": {
        "title": "Load Input Video"
      }
    },
    "2": {
      "class_type": "UNETLoader",
      "inputs": {
        "unet_name": "realesrgan_x4plus.safetensors",
        "weight_dtype": "default"
      },
      "_meta": {
        "title": "Load Upscaling Model"
      }
    },
    "3": {
      "class_type": "VAELoader",
      "inputs": {
        "vae_name": "vae-ft-mse-840000-ema-pruned.safetensors"
      },
      "_meta": {
        "title": "Load VAE"
      }
    },
    "4": {
      "class_type": "CLIPLoader",
      "inputs": {
        "clip_name": "clip_l.safetensors",
        "type": "stable_diffusion",
        "device": "default"
      },
      "_meta": {
        "title": "Load CLIP"
      }
    },
    "5": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "high resolution, sharp details, enhanced quality, 4k, crisp",
        "clip": ["4", 0]
      },
      "_meta": {
        "title": "Upscaling Prompt"
      }
    },
    "6": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "blurry, pixelated, low quality, compression artifacts, noise",
        "clip": ["4", 0]
      },
      "_meta": {
        "title": "Negative Prompt"
      }
    },
    "7": {
      "class_type": "VideoFrameExtractor",
      "inputs": {
        "video": ["1", 0],
        "frame_rate": 24,
        "max_frames": 300
      },
      "_meta": {
        "title": "Extract Video Frames"
      }
    },
    "8": {
      "class_type": "UpscaleModelLoader",
      "inputs": {
        "model_name": "RealESRGAN_x4plus.pth"
      },
      "_meta": {
        "title": "Load Real-ESRGAN Upscaler"
      }
    },
    "9": {
      "class_type": "ImageUpscaleWithModel",
      "inputs": {
        "upscale_model": ["8", 0],
        "image": ["7", 0]
      },
      "_meta": {
        "title": "Upscale Frames with Real-ESRGAN"
      }
    },
    "10": {
      "class_type": "VAEEncode",
      "inputs": {
        "pixels": ["9", 0],
        "vae": ["3", 0]
      },
      "_meta": {
        "title": "Encode Upscaled Frames"
      }
    },
    "11": {
      "class_type": "KSampler",
      "inputs": {
        "seed": 12345,
        "steps": 8,
        "cfg": 2.0,
        "sampler_name": "dpmpp_2m",
        "scheduler": "karras",
        "denoise": 0.3,
        "model": ["2", 0],
        "positive": ["5", 0],
        "negative": ["6", 0],
        "latent_image": ["10", 0]
      },
      "_meta": {
        "title": "Refine Upscaled Frames"
      }
    },
    "12": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": ["11", 0],
        "vae": ["3", 0]
      },
      "_meta": {
        "title": "Decode Enhanced Frames"
      }
    },
    "13": {
      "class_type": "CreateVideo",
      "inputs": {
        "fps": 24,
        "images": ["12", 0]
      },
      "_meta": {
        "title": "Reassemble Upscaled Video"
      }
    },
    "14": {
      "class_type": "SaveVideo",
      "inputs": {
        "filename_prefix": "video/upscaled_",
        "format": "mp4",
        "codec": "h264",
        "video": ["13", 0]
      },
      "_meta": {
        "title": "Save Upscaled Video"
      }
    }
  },
  "fields": [
    {
      "id": "file_1_video",
      "label": "Input Video",
      "type": "file",
      "required": true,
      "nodeId": "1",
      "inputKey": "video",
      "help": "Upload the video you want to upscale"
    },
    {
      "id": "text_5_text",
      "label": "Enhancement Prompt",
      "type": "text",
      "required": true,
      "defaultValue": "high resolution, sharp details, enhanced quality, 4k, crisp",
      "nodeId": "5",
      "inputKey": "text"
    },
    {
      "id": "text_6_text",
      "label": "Negative Prompt",
      "type": "text",
      "required": false,
      "defaultValue": "blurry, pixelated, low quality, compression artifacts, noise",
      "nodeId": "6",
      "inputKey": "text"
    },
    {
