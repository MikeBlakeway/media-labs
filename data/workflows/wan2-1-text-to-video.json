{
  "slug": "wan2-1-text-to-video",
  "name": "Text to Video (Wan 2.1 T2V)",
  "outputType": "video",
  "workflow": {
    "1": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "a majestic eagle soaring through a dramatic mountain landscape with golden sunset lighting, cinematic, high quality",
        "clip": ["8", 0]
      },
      "_meta": {
        "title": "CLIP Text Encode (Positive Prompt)"
      }
    },
    "2": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "blurry, low quality, static, motionless, bad anatomy, distorted, artifacts",
        "clip": ["8", 0]
      },
      "_meta": {
        "title": "CLIP Text Encode (Negative Prompt)"
      }
    },
    "3": {
      "class_type": "KSampler",
      "inputs": {
        "seed": 12345,
        "steps": 25,
        "cfg": 8.0,
        "sampler_name": "uni_pc",
        "scheduler": "simple",
        "denoise": 1.0,
        "model": ["9", 0],
        "positive": ["1", 0],
        "negative": ["2", 0],
        "latent_image": ["4", 0]
      },
      "_meta": {
        "title": "KSampler"
      }
    },
    "4": {
      "class_type": "WanTextToVideo",
      "inputs": {
        "width": 720,
        "height": 480,
        "length": 25,
        "batch_size": 1,
        "positive": ["1", 0],
        "negative": ["2", 0],
        "vae": ["7", 0]
      },
      "_meta": {
        "title": "Wan Text To Video"
      }
    },
    "5": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": ["3", 0],
        "vae": ["7", 0]
      },
      "_meta": {
        "title": "VAE Decode"
      }
    },
    "6": {
      "class_type": "UNETLoader",
      "inputs": {
        "unet_name": "wan2.1_t2v_1.3B_fp16.safetensors",
        "weight_dtype": "default"
      },
      "_meta": {
        "title": "Load T2V Model"
      }
    },
    "7": {
      "class_type": "VAELoader",
      "inputs": {
        "vae_name": "wan_2.1_vae.safetensors"
      },
      "_meta": {
        "title": "Load VAE"
      }
    },
    "8": {
      "class_type": "CLIPLoader",
      "inputs": {
        "clip_name": "umt5_xxl_fp8_e4m3fn_scaled.safetensors",
        "type": "wan",
        "device": "default"
      },
      "_meta": {
        "title": "Load CLIP"
      }
    },
    "9": {
      "class_type": "ModelSamplingSD3",
      "inputs": {
        "shift": 8,
        "model": ["6", 0]
      },
      "_meta": {
        "title": "Model Sampling"
      }
    },
    "10": {
      "class_type": "CreateVideo",
      "inputs": {
        "fps": 16,
        "images": ["5", 0]
      },
      "_meta": {
        "title": "Create Video"
      }
    },
    "11": {
      "class_type": "SaveVideo",
      "inputs": {
        "filename_prefix": "t2v/MediaLabs",
        "format": "mp4",
        "codec": "h264",
        "video": ["10", 0]
      },
      "_meta": {
        "title": "Save Video"
      }
    }
  },
