{
  "name": "media-labs",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "dev:ui": "pnpm --filter ./apps/ui run dev",
    "dev:api": "pnpm --filter ./apps/api run dev",
    "dev:worker": "pnpm --filter ./apps/worker run dev",
    "dev:turbo": "turbo run dev --parallel",
    "dev": "pnpm run dev:turbo",
    "build:ui": "pnpm --filter ./apps/ui run build",
    "build:api": "pnpm --filter ./apps/api run build",
    "build:worker": "pnpm --filter ./apps/worker run build",
    "build": "pnpm -r run build",
    "start:ui": "pnpm --filter ./apps/ui run start",
    "lint": "pnpm -r run lint",
    "format": "pnpm --filter \"./apps/*\" --filter \"./packages/*\" -r run format",
    "test": "pnpm -r test || true",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "turbo:link": "pnpm dlx turbo link",
    "turbo:clean": "rm -rf .turbo && pnpm -w -r run clean || true",
    "lint-staged": "lint-staged",
    "bootstrap:flf2v": "node scripts/github-bootstrap-flf2v.js",
    "validate:flf2v": "node scripts/validate-flf2v-bootstrap.js"
  },
  "prepare": "husky install",
  "dependencies": {
    "next": "15.5.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.0.0",
    "@commitlint/config-conventional": "^17.0.0",
    "@eslint/eslintrc": "^3",
    "@octokit/rest": "^20.0.0",
    "@playwright/test": "^1.55.0",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^9.0.0",
    "lint-staged": "^16.1.5",
    "prettier": "^2.5.0",
    "turbo": "^1.9.0",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "pnpm -w -s eslint --fix --no-ignore --"
    ],
    "*.{json,md,css,scss,mdx}": [
      "pnpm -w -s prettier --write"
    ]
  }
}
