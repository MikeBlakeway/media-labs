{
  "name": "@media-labs/worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "docker-compose up --build",
    "build": "docker build -f Dockerfile -t ghcr.io/mikeblakeway/media-labs-worker:latest .",
    "push": "docker push ghcr.io/mikeblakeway/media-labs-worker:latest",
    "test": "python -m pytest tests/ -v",
    "lint": "ruff check src/ tests/",
    "format": "ruff format src/ tests/",
    "shell": "docker run -it --rm ghcr.io/mikeblakeway/media-labs-worker:latest /bin/bash"
  },
  "devDependencies": {
    "ruff": "^0.1.0",
    "pytest": "^7.0.0"
  }
}
