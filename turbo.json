{
  "$schema": "./node_modules/turbo/schema.json",
  "cacheDir": ".turbo",
  "globalDependencies": ["tsconfig.json", ".env*"],
  "remoteCache": {
    "enabled": false,
    "signature": false,
    "preflight": false,
    "timeout": 30,
    "uploadTimeout": 60
  },
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "outputLogs": "new-only"
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": ["coverage/**"]
    },
    "type-check": {
      "dependsOn": ["^type-check"],
      "outputs": []
    },
    "start": {
      "cache": false,
      "persistent": true
    }
  }
}
